{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "languages": {
        "python": {
          "version": "3.11"
        }
      }
    }
  },
  "deploy": {
    "numInstances": 1,
    "startCommand": "gunicorn app:app --bind :$PORT",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
