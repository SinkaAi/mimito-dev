{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "gunicorn app:app --bind 0.0.0.0:$PORT --workers 2 --config gunicorn.conf.py"
  }
}
